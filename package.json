{
  "name": "template-react-ts-tw-fullstack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:*",
    "dev:client": "cd client && bun run dev",
    "dev:server": "cd server && bun run dev",
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd client && bun run build",
    "build:server": "cd server && bun run build",
    "preview": "cd client && bun run preview",
    "start": "cd server && bun run start",
    "lint": "bun run --parallel lint:*",
    "lint:client": "cd client && bun run lint",
    "lint:server": "cd server && bun run lint"
  },
  "workspaces": ["client", "server"],
  "devDependencies": {
    "bun-types": "^1.1.0"
  }
}
